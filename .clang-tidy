---
# Focused on real-bug categories. Style preferences (naming length,
# trailing-return-type, magic numbers) are left for code review, not
# enforced by the linter.
#
# CI runs `clang-tidy --warnings-as-errors=*` on every changed C++
# file; any diagnostic from the categories below fails the build. Add
# a check here, do not silence with `// NOLINT` per-site.
Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  -cert-dcl50-cpp,
  -cert-err58-cpp,
  clang-analyzer-*,
  -clang-analyzer-optin.cplusplus.VirtualCall,
  performance-*,
  -performance-enum-size,
  portability-*,
  -portability-avoid-pragma-once,
  -portability-template-virtual-member-function,
  misc-*,
  -misc-const-correctness,
  -misc-include-cleaner,
  -misc-no-recursion,
  -misc-non-private-member-variables-in-classes,
  -misc-use-anonymous-namespace,
  -misc-use-internal-linkage,
  -clang-diagnostic-deprecated-declarations,
  -clang-diagnostic-ignored-gch
WarningsAsErrors: '*'
HeaderFilterRegex: '(core|sdk|plugins)/.*\.(hpp|h)$'
FormatStyle: none
...
