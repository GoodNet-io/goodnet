#!/usr/bin/env bash
# Pre-commit hook: run clang-tidy strict on staged C++ files so CI's
# `--warnings-as-errors=*` lint gate cannot surprise the author at PR
# time. Bypass with `git commit --no-verify` if a staged change is
# intentionally noisy (rare; prefer fixing the diagnostic).
#
# Wires through CMake's `compile_commands.json` from the `build/`
# directory; `nix run .#dev` populates it. clang-tidy needs every
# `-isystem` flag the dev shell injects through `NIX_CFLAGS_COMPILE`
# (gtest, spdlog, boost) — git launches hooks with a stripped env, so
# the body re-enters `nix develop` and runs there.
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(cpp|hpp|h|cc)$' || true)

staged_all=$(git diff --cached --name-only --diff-filter=ACMR || true)

# ── ABI hermeticity gate ────────────────────────────────────────────
# Boundary rule per `docs/contracts/abi-evolution.en.md` §3:
#   `core/` ↛ `plugins/`  — kernel never #includes plugin headers
#   `plugins/` ↛ `core/`  — plugins never reach kernel internals
# Cross-plugin private headers (`plugins/A/foo.hpp` from `plugins/B/`)
# are also banned — extensions are the only inter-plugin surface.
abi_violations=0
if [ -n "$staged" ]; then
    while IFS= read -r f; do
        [ -f "$f" ] || continue
        case "$f" in
            core/*)
                if grep -nE '^#include[[:space:]]+["<]plugins/' "$f" >&2; then
                    echo "pre-commit: $f — kernel must not include plugin headers" >&2
                    abi_violations=$((abi_violations + 1))
                fi
                ;;
            plugins/*)
                if grep -nE '^#include[[:space:]]+["<]core/' "$f" >&2; then
                    echo "pre-commit: $f — plugin must not include kernel internals" >&2
                    abi_violations=$((abi_violations + 1))
                fi
                plugin_path=$(printf '%s' "$f" | awk -F/ '{print $1"/"$2"/"$3}')
                while IFS= read -r inc; do
                    case "$inc" in
                        "${plugin_path}/"*) ;;
                        plugins/*)
                            echo "pre-commit: $f includes $inc — cross-plugin private headers banned" >&2
                            abi_violations=$((abi_violations + 1))
                            ;;
                    esac
                done < <(grep -oE '#include[[:space:]]+["<]plugins/[^">]+' "$f" \
                            | sed -E 's|.*[<"]||')
                ;;
        esac
    done <<< "$staged"
fi

# ── Banlist gate ────────────────────────────────────────────────────
# Hardcoded plugin name string literals in `core/` couple the kernel
# to specific plugin identities. Plan vocab in repo artefacts warns
# (not block) — `Phase X` / `LA.3` / `ML.1` should land in private
# plans, not commits.
banlist_violations=0
if [ -n "$staged_all" ]; then
    while IFS= read -r f; do
        [ -f "$f" ] || continue
        case "$f" in
            core/*.cpp|core/*.hpp|core/*.h|core/*/*.cpp|core/*/*.hpp|core/*/*.h|core/*/*/*.cpp|core/*/*/*.hpp|core/*/*/*.h)
                # Catch complete plugin-name literals (`"gn.link.tcp"`,
                # `"gn.security.noise"`, …). The `gn.link.%.*s` runtime
                # format string used to assemble per-scheme extension
                # names is fine — it does not bind the kernel to any
                # specific plugin id. Require the segment after the
                # family prefix to start with a lowercase letter to
                # exclude format placeholders.
                if grep -nE '"gn\.(link|handler|security|protocol|strategy)\.[a-z][a-z0-9_-]*"' "$f" >&2; then
                    echo "pre-commit: $f — hardcoded plugin name literal in kernel" >&2
                    banlist_violations=$((banlist_violations + 1))
                fi
                ;;
        esac
        case "$f" in
            *.cpp|*.hpp|*.h|*.cc|docs/spec/*.md|docs/contracts/*.md)
                # Plan vocab + audit identifier scrub. Plan slots
                # (`Phase X`, `LA.N`, `ML.N`, `CK-N`, `FA-N`) and
                # audit-report identifiers (`B-LINKS-N`, `D-LINKS-N`,
                # `S-LINKS-N`, `W2-X` family rows, `PA-N`, `MF-N`,
                # Tier ratchet codes like `T1·N` / `U-T2·N`, and
                # `Wave-N` references) live in private plans and
                # audit corpora — not in repo artefacts. Commits
                # describe WHY a change lands as standalone prose;
                # the audit row stays in the planner's working copy.
                vocab_re='\bPhase [A-Z]\b|\bLA\.[0-9]+\b|\bML\.[0-9]+\b|\bCK-[0-9]+\b|\bFA-[0-9]+\b'
                audit_re='\b[BDS]-LINKS-[0-9]+\b|\bW2-[A-Z][a-z]?\b|\bPA-[0-9]+\b|\bMF-[0-9]+\b|\bU?-?T[1-3]·[0-9]+\b|\bWave-[12]\b'
                if grep -qnE "${vocab_re}|${audit_re}" "$f" 2>/dev/null; then
                    grep -nE "${vocab_re}|${audit_re}" "$f" >&2
                    echo "pre-commit: $f — plan vocab / audit IDs in repo artefact (warning, not blocking)" >&2
                fi
                ;;
        esac
    done <<< "$staged_all"
fi

if [ "$abi_violations" -gt 0 ] || [ "$banlist_violations" -gt 0 ]; then
    echo "" >&2
    echo "pre-commit: $abi_violations ABI + $banlist_violations banlist violation(s)." >&2
    echo "pre-commit: bypass with \`git commit --no-verify\` only for backwards-compat shims." >&2
    exit 1
fi

[ -z "$staged" ] && exit 0

if [ ! -f build/compile_commands.json ]; then
    echo "pre-commit: build/compile_commands.json missing — run \`nix run .#dev\` first" >&2
    echo "pre-commit: bypass with \`git commit --no-verify\` if intentional" >&2
    exit 1
fi

# Re-enter the dev shell. `_GN_PRECOMMIT_INSIDE` guards against
# infinite recursion if the user already spawned the hook from
# inside a dev shell that re-execs the script.
if [ -z "${_GN_PRECOMMIT_INSIDE:-}" ]; then
    export _GN_PRECOMMIT_INSIDE=1
    exec nix develop "${FLAKE_DIR:-.}" --command bash -- "$0" "$@"
fi

failed=0
while IFS= read -r f; do
    [ -f "$f" ] || continue
    output=$(clang-tidy --quiet --warnings-as-errors='*' \
                -p build "$f" 2>&1 || true)
    if printf '%s\n' "$output" | grep -qE "error:|treated as errors"; then
        printf '%s\n' "$output" >&2
        echo "pre-commit: clang-tidy failed on $f" >&2
        failed=$((failed + 1))
    fi
done <<< "$staged"

if [ $failed -gt 0 ]; then
    echo "" >&2
    echo "pre-commit: $failed file(s) failed strict tidy. Fix or run with --no-verify." >&2
    exit 1
fi

exit 0
