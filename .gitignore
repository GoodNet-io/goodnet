# Inverted gitignore: ignore everything, whitelist what we need.
# Directories must be un-ignored for git to traverse into them.
*
!*/

# Top-level project files
!.gitignore
!.envrc
!.clang-tidy
!flake.nix
!flake.lock
!CMakeLists.txt
!Makefile
!LICENSE
!README.md
!README.ru.md
!CHANGELOG.md
!SECURITY.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!GOVERNANCE.md

# Git hooks (opt-in via `nix run .#install-hooks`)
!.githooks/*

# Editor configs
!.vscode/*.json

# Build / output dirs (re-block after top-level rules)
build/
build-*/
result
result-*
.direnv/
.cache/

# CMake helpers
!cmake/*.cmake
!cmake/*.cmake.in
!cmake/*.cpp.in

# Nix helpers (per-plugin Nix derivations)
!nix/*.nix
!nix/*.sh

# Docs
!docs/**/*.md
!docs/Doxyfile
!docs/img/*.svg
!docs/architecture.canvas
# Livedoc fact extracts — diff-friendly YAML produced from sdk/*.h
# and plugin trees by `tools/livedoc.py`. Committed so the rendered
# markdown stays accurate without operators having to run the
# generator themselves.
!docs/_facts/*.yaml

# Diagram + math generators
!tools/*.py
!tools/math/*.py
# Livedoc package — abi_extract, renderers, roadmap resolver,
# inventory walker, plus the YAML feature map.
!tools/livedoc/*.py
!tools/livedoc/*.yaml
__pycache__/

# CI
!.github/**/*.yml
!.github/**/*.yaml

# SDK (header-only headers + the worker stub static library — the
# stub mirrors `core/plugin/remote_host.*` from the worker side so
# every binding can link a C++ reference implementation; pinned in
# `docs/contracts/remote-plugin.en.md` §10).
!sdk/**/*.h
!sdk/**/*.hpp
!sdk/**/*.cpp
!sdk/**/CMakeLists.txt
!sdk/LICENSE

# Kernel
!core/**/*.cpp
!core/**/*.hpp
!core/**/*.h
!core/**/*.in
!core/**/CMakeLists.txt
!core/LICENSE

# Plugins. The monorepo tracks the structural top-level
# `plugins/CMakeLists.txt` plus everything under
# `plugins/protocols/` (gnet + raw — both `add_library(... STATIC)`
# linked into the kernel binary, so the kernel build genuinely
# depends on their source). Loadable plugins under
# `plugins/handlers/`, `plugins/links/`, `plugins/security/`
# live in their own gits (one per plugin directory) and are
# deliberately not tracked by the monorepo — the explicit
# directory blocks below stop git from auto-registering each
# nested `.git/` as a submodule when something runs
# `git add -A` from the monorepo root.
!plugins/CMakeLists.txt
!plugins/protocols/**
# Subprocess plugin workers. The in-tree `remote_echo` proof rides
# under `plugins/workers/` and ships with the kernel monorepo (it's
# the single integration smoke for `RemoteHost`). Real workers live
# in their own gits the same way other plugins do.
!plugins/workers/**/*.cpp
!plugins/workers/**/*.hpp
!plugins/workers/**/CMakeLists.txt
plugins/handlers/heartbeat/
plugins/handlers/store/
plugins/handlers/dns/
plugins/handlers/mycelium/
plugins/links/tcp/
plugins/links/udp/
plugins/links/ws/
plugins/links/ipc/
plugins/links/tls/
plugins/links/ice/
plugins/links/quic/
plugins/security/noise/
plugins/security/null/

# bridges/cpp/ is the slot for the bridges-cpp repo — operator-side
# C++ binding over `sdk/core.h`. Lives in its own git (mirror at
# `~/.local/share/goodnet-mirrors/bridges-cpp.git`); the explicit
# block stops git from auto-registering the nested `.git/` as a
# submodule when something runs `git add -A` from the monorepo root.
bridges/cpp/

# tests/integration/ is the slot for the goodnet-integration-tests
# repo — pulled by `install-plugins`, gitignored from the kernel
# the same way as plugin slots so the nested .git stays invisible
# to `git add -A`.
tests/integration/

# Tests
!tests/**/*.c
!tests/**/*.cpp
!tests/**/*.h
!tests/**/*.hpp
!tests/**/*.conf
!tests/**/CMakeLists.txt
# Python-side unit suite for tools/livedoc/.
!tests/**/*.py
!pytest.ini

# Examples
!examples/**/*.cpp
!examples/**/*.hpp
!examples/**/*.md
!examples/**/CMakeLists.txt
!examples/**/LICENSE

# Bench suite
!bench/**/*.cpp
!bench/**/*.hpp
!bench/**/*.md
!bench/**/*.sh
!bench/**/*.py
!bench/**/*.rs
!bench/**/*.toml
!bench/**/CMakeLists.txt
!bench/**/LICENSE

# Apps (operator-facing CLI binaries)
!apps/**/*.cpp
!apps/**/*.hpp
!apps/**/*.md
!apps/**/CMakeLists.txt

# Distribution artefacts (systemd units, example configs, packaging)
!dist/**/*.service
!dist/**/*.json
!dist/**/*.md
!dist/**/Dockerfile*

# manifesto/ is a separate writing repo (per MEMORY.md), not a submodule
manifesto/
plugins/strategies/
