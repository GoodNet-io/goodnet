# Inverted gitignore: ignore everything, whitelist what we need.
# Directories must be un-ignored for git to traverse into them.
*
!*/

# Top-level project files
!.gitignore
!.envrc
!.clang-tidy
!flake.nix
!flake.lock
!CMakeLists.txt
!LICENSE
!README.md
!README.ru.md
!CHANGELOG.md
!SECURITY.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!GOVERNANCE.md

# Git hooks (opt-in via `nix run .#install-hooks`)
!.githooks/*

# Editor configs
!.vscode/*.json

# Build / output dirs (re-block after top-level rules)
build/
build-*/
result
result-*
.direnv/
.cache/

# CMake helpers
!cmake/*.cmake
!cmake/*.cmake.in

# Nix helpers (per-plugin Nix derivations)
!nix/*.nix
!nix/*.sh

# Docs
!docs/**/*.md
!docs/Doxyfile

# CI
!.github/**/*.yml
!.github/**/*.yaml

# SDK (header-only)
!sdk/**/*.h
!sdk/**/*.hpp
!sdk/**/CMakeLists.txt
!sdk/LICENSE

# Kernel
!core/**/*.cpp
!core/**/*.hpp
!core/**/*.h
!core/**/*.in
!core/**/CMakeLists.txt
!core/LICENSE

# Plugins (in-tree development convenience). Each plugin also
# carries its own `.gitignore` (inverted whitelist tuned for the
# plugin's standalone git repository). The monorepo tracks those
# `.gitignore` files alongside source so a fresh clone has them
# without re-running `nix run .#new-plugin`.
!plugins/**/.gitignore
!plugins/**/.clang-tidy
!plugins/**/*.cpp
!plugins/**/*.hpp
!plugins/**/*.h
!plugins/**/*.json
!plugins/**/CMakeLists.txt
!plugins/**/default.nix
!plugins/**/flake.nix
# `flake.lock` is the plugin's own git's concern — including it
# in the monorepo's index makes every per-plugin re-lock dirty
# the monorepo's working tree, which in turn dirties the kernel
# input the next plugin tries to lock against. Leave it to the
# nested git.
!plugins/**/LICENSE
!plugins/**/README.md

# Tests
!tests/**/*.c
!tests/**/*.cpp
!tests/**/*.h
!tests/**/*.hpp
!tests/**/*.conf
!tests/**/CMakeLists.txt

# Examples
!examples/**/*.cpp
!examples/**/*.hpp
!examples/**/*.md
!examples/**/CMakeLists.txt
!examples/**/LICENSE

# Apps (operator-facing CLI binaries)
!apps/**/*.cpp
!apps/**/*.hpp
!apps/**/*.md
!apps/**/CMakeLists.txt

# Distribution artefacts (systemd units, example configs, packaging)
!dist/**/*.service
!dist/**/*.json
!dist/**/*.md

# manifesto/ is a separate writing repo (per MEMORY.md), not a submodule
manifesto/
